# Copy this file to .env.local for local overrides
# In production (Vercel), set these as Environment Variables in the dashboard

# Your Railway backend URL, e.g. https://skychat-backend.up.railway.app
VITE_API_URL=https://YOUR_BACKEND_URL/api

# Your Railway backend WebSocket URL
VITE_WS_URL=https://YOUR_BACKEND_URL/ws
